---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLocaleFromUrl, useTranslations } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---

<BaseLayout
  title={`LeanCTX Cloud`}
  description="Sync stats, knowledge, and adaptive models across devices. Free for all logged-in users."
  breadcrumbs={[{ name: 'Cloud', url: '/cloud' }]}
>
  <section class="content-grid py-12 md:py-16">
    <div class="max-w-5xl mx-auto">
      <div class="glass-panel p-8 md:p-10 animate-entrance">
        <div class="flex flex-col gap-3">
          <p class="text-sm text-muted">{t('nav.product.contextServer')}</p>
          <h1 class="text-3xl md:text-4xl font-display text-text-bright">LeanCTX Cloud</h1>
          <p class="text-base md:text-lg text-text max-w-3xl">
            Kostenlos. Opt-in via Login. Self-hosted auf unseren Servern. Synchronisiert Stats, Knowledge und adaptive models.
          </p>
        </div>

        <div id="cloudError" class="mt-6 hidden rounded-xl border border-red-500/30 bg-red-500/10 p-4 text-sm text-red-200"></div>
        <div id="cloudInfo" class="mt-6 hidden rounded-xl border border-emerald-500/30 bg-emerald-500/10 p-4 text-sm text-emerald-200"></div>

        <div id="loginCard" class="mt-8 grid grid-cols-1 md:grid-cols-[1fr_auto] gap-3 items-end">
          <div>
            <label for="email" class="block text-sm text-muted mb-2">Email</label>
            <input
              id="email"
              type="email"
              autocomplete="email"
              inputmode="email"
              class="w-full rounded-xl bg-bg/40 border border-white/10 px-4 py-3 text-text-bright placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-accent/50"
              placeholder="you@company.com"
            />
          </div>
          <button
            id="sendLinkBtn"
            class="rounded-xl px-5 py-3 bg-accent text-bg font-semibold hover:brightness-110 transition disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Magic-Link senden
          </button>
        </div>

        <div id="authedArea" class="mt-10 hidden">
          <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3">
            <div class="text-sm text-muted">
              Status: <span id="cloudStatus" class="text-text-bright font-medium">verbunden</span>
            </div>
            <div class="flex gap-2">
              <button id="refreshBtn" class="rounded-xl px-4 py-2 border border-white/10 bg-bg/30 hover:bg-bg/40 transition">
                Refresh
              </button>
              <button id="logoutBtn" class="rounded-xl px-4 py-2 border border-white/10 bg-bg/30 hover:bg-bg/40 transition">
                Logout
              </button>
            </div>
          </div>

          <div class="mt-6 grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div class="glass-panel p-6">
              <h2 class="text-lg font-semibold text-text-bright">{t('profile.title')}</h2>
              <div id="profileBox" class="mt-4 text-sm text-muted">Loading…</div>
            </div>

            <div class="glass-panel p-6">
              <h2 class="text-lg font-semibold text-text-bright">{t('profile.team')}</h2>
              <div id="teamBox" class="mt-4 text-sm text-muted">Loading…</div>
            </div>
          </div>

          <div class="mt-6 grid grid-cols-1 lg:grid-cols-3 gap-6">
            <div class="glass-panel p-6">
              <h2 class="text-lg font-semibold text-text-bright">Stats</h2>
              <p class="text-sm text-muted mt-1">Letzte 120 Tage (daily sync).</p>
              <div id="statsBox" class="mt-4 text-sm text-muted">Loading…</div>
            </div>

            <div class="glass-panel p-6">
              <h2 class="text-lg font-semibold text-text-bright">Adaptive models</h2>
              <p class="text-sm text-muted mt-1">Empfohlene Read-Modes pro Datei-Signatur.</p>
              <div id="modelsBox" class="mt-4 text-sm text-muted">Loading…</div>
            </div>

            <div class="glass-panel p-6">
              <h2 class="text-lg font-semibold text-text-bright">Knowledge</h2>
              <p class="text-sm text-muted mt-1">Dein synchronisiertes Wissen.</p>
              <div id="knowledgeBox" class="mt-4 text-sm text-muted">Loading…</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script type="module">
    const API_BASE = 'https://api.leanctx.com';

    const elError = document.getElementById('cloudError');
    const elInfo = document.getElementById('cloudInfo');
    const loginCard = document.getElementById('loginCard');
    const authedArea = document.getElementById('authedArea');
    const statusEl = document.getElementById('cloudStatus');

    const statsBox = document.getElementById('statsBox');
    const modelsBox = document.getElementById('modelsBox');
    const knowledgeBox = document.getElementById('knowledgeBox');
    const profileBox = document.getElementById('profileBox');
    const teamBox = document.getElementById('teamBox');

    const emailInput = document.getElementById('email');
    const sendBtn = document.getElementById('sendLinkBtn');
    const refreshBtn = document.getElementById('refreshBtn');
    const logoutBtn = document.getElementById('logoutBtn');

    function show(el, html) {
      el.classList.remove('hidden');
      el.textContent = html;
    }
    function hide(el) {
      el.classList.add('hidden');
      el.textContent = '';
    }

    async function fetchJson(path, opts = {}) {
      const res = await fetch(API_BASE + path, {
        ...opts,
        credentials: 'include',
        headers: {
          'Content-Type': 'application/json',
          ...(opts.headers || {}),
        },
      });
      const text = await res.text();
      const data = text ? (() => { try { return JSON.parse(text); } catch { return text; } })() : null;
      if (!res.ok) {
        const msg = typeof data === 'string' ? data : (data?.message || data?.error || res.statusText);
        const err = new Error(msg || `HTTP ${res.status}`);
        err.status = res.status;
        throw err;
      }
      return data;
    }

    function renderStats(rows) {
      if (!Array.isArray(rows) || rows.length === 0) {
        statsBox.textContent = 'Noch keine Stats (run: lean-ctx sync).';
        return;
      }
      const top = rows.slice(0, 10);
      const lines = top.map(r => {
        const d = r.date ?? '?';
        const saved = r.tokens_saved ?? 0;
        const calls = r.tool_calls ?? 0;
        return `${d}  ·  saved=${saved}  ·  calls=${calls}`;
      });
      statsBox.textContent = lines.join('\n');
      statsBox.style.whiteSpace = 'pre';
    }

    function renderModels(resp) {
      const models = resp?.models;
      if (!Array.isArray(models) || models.length === 0) {
        modelsBox.textContent = 'Noch keine Models (contributions fehlen).';
        return;
      }
      const top = models.slice(0, 12);
      const lines = top.map(m => {
        const ext = m.file_ext ?? '?';
        const b = m.size_bucket ?? '?';
        const mode = m.recommended_mode ?? '?';
        const c = typeof m.confidence === 'number' ? Math.round(m.confidence * 100) : 0;
        return `${ext} ${b}  →  ${mode}  (${c}%)`;
      });
      modelsBox.textContent = lines.join('\n');
      modelsBox.style.whiteSpace = 'pre';
    }

    function renderKnowledge(entries) {
      if (!Array.isArray(entries) || entries.length === 0) {
        knowledgeBox.textContent = 'Noch keine Knowledge Entries.';
        return;
      }
      const top = entries.slice(0, 12);
      const lines = top.map(e => {
        const cat = e.category ?? '?';
        const key = e.key ?? '?';
        return `[${cat}] ${key}`;
      });
      knowledgeBox.textContent = lines.join('\n');
      knowledgeBox.style.whiteSpace = 'pre';
    }

    function fmtTokens(n) {
      if (n >= 1e9) return (n / 1e9).toFixed(1) + 'B';
      if (n >= 1e6) return (n / 1e6).toFixed(1) + 'M';
      if (n >= 1e3) return (n / 1e3).toFixed(1) + 'K';
      return String(n);
    }

    const badgeEmoji = {
      'First Save': '\u2B50', 'Token Saver 1M': '\uD83E\uDD47',
      'Token Saver 10M': '\uD83E\uDD48', 'Token Saver 100M': '\uD83C\uDFC6',
      'Evangelist': '\uD83D\uDCE3', 'Team Builder': '\uD83D\uDC65',
      'Early Adopter': '\uD83D\uDE80', 'Contributor': '\uD83D\uDEE0\uFE0F'
    };

    function renderProfile(data) {
      if (!data || !data.display_hash) {
        profileBox.textContent = 'Could not load profile.';
        return;
      }
      const name = data.username || data.display_hash;
      const badges = (data.badges || []).map(b => `<span title="${b}" style="cursor:help">${badgeEmoji[b] || b}</span>`).join(' ');
      const inviteUrl = `${window.location.origin}/docs/getting-started?ref=${data.invite_code}`;

      profileBox.innerHTML = `
        <div style="display:flex;flex-direction:column;gap:0.75rem;">
          <div><span style="color:var(--color-muted)">Hash:</span> <strong style="color:var(--color-text-bright)">${name}</strong></div>
          <div><span style="color:var(--color-muted)">Rank:</span> <strong style="color:var(--color-accent)">#${data.rank}</strong></div>
          <div><span style="color:var(--color-muted)">Saved:</span> <strong style="color:var(--color-accent)">${fmtTokens(data.total_tokens_saved)}</strong></div>
          <div><span style="color:var(--color-muted)">Badges:</span> ${badges || '<span style="opacity:0.5">none yet</span>'}</div>
          <div style="margin-top:0.5rem;">
            <span style="color:var(--color-muted);font-size:0.75rem">Invite Link:</span>
            <div style="display:flex;gap:0.5rem;margin-top:0.25rem;">
              <input id="inviteInput" type="text" readonly value="${inviteUrl}" style="flex:1;padding:0.4rem 0.6rem;border-radius:8px;border:1px solid rgba(255,255,255,0.1);background:rgba(0,0,0,0.3);color:var(--color-text-bright);font-size:0.75rem;font-family:var(--font-mono,monospace);" />
              <button id="copyInviteBtn" style="padding:0.4rem 0.8rem;border-radius:8px;border:1px solid rgba(255,255,255,0.1);background:transparent;color:var(--color-accent);font-size:0.75rem;cursor:pointer;">Copy</button>
            </div>
          </div>
        </div>`;

      document.getElementById('copyInviteBtn')?.addEventListener('click', () => {
        const input = document.getElementById('inviteInput');
        if (input) {
          navigator.clipboard.writeText(input.value).then(() => {
            document.getElementById('copyInviteBtn').textContent = 'Copied!';
            setTimeout(() => { document.getElementById('copyInviteBtn').textContent = 'Copy'; }, 2000);
          });
        }
      });
    }

    function renderTeam(data) {
      if (!data || !data.team) {
        teamBox.innerHTML = '<p style="color:var(--color-muted)">No team yet — share your invite code to create one!</p>';
        return;
      }
      const t = data.team;
      teamBox.innerHTML = `
        <div style="display:flex;flex-direction:column;gap:0.75rem;">
          <div><span style="color:var(--color-muted)">Name:</span> <strong style="color:var(--color-text-bright)">${t.name}</strong> ${t.is_owner ? '<span style="color:var(--color-accent);font-size:0.75rem">(Owner)</span>' : ''}</div>
          <div><span style="color:var(--color-muted)">Members:</span> <strong>${t.member_count}</strong></div>
          <div><span style="color:var(--color-muted)">Team Saved:</span> <strong style="color:var(--color-accent)">${fmtTokens(t.total_tokens_saved)}</strong></div>
          <div style="display:flex;gap:0.5rem;margin-top:0.5rem;">
            <button id="leaveTeamBtn" style="padding:0.4rem 0.8rem;border-radius:8px;border:1px solid rgba(255,255,255,0.1);background:transparent;color:var(--color-muted);font-size:0.75rem;cursor:pointer;">Leave Team</button>
            ${t.is_owner ? '<button id="renameTeamBtn" style="padding:0.4rem 0.8rem;border-radius:8px;border:1px solid rgba(255,255,255,0.1);background:transparent;color:var(--color-muted);font-size:0.75rem;cursor:pointer;">Rename</button>' : ''}
          </div>
        </div>`;

      document.getElementById('leaveTeamBtn')?.addEventListener('click', async () => {
        if (!confirm('Leave team?')) return;
        try {
          await fetchJson('/api/profile/leave-team', { method: 'POST', body: '{}' });
          loadAll();
        } catch (e) { show(elError, e?.message || 'Failed'); }
      });

      document.getElementById('renameTeamBtn')?.addEventListener('click', async () => {
        const name = prompt('New team name:', t.name);
        if (!name || !name.trim()) return;
        try {
          await fetchJson('/api/profile/rename-team', { method: 'POST', body: JSON.stringify({ name: name.trim() }) });
          loadAll();
        } catch (e) { show(elError, e?.message || 'Failed'); }
      });
    }

    async function loadAll() {
      hide(elError);
      hide(elInfo);
      statusEl.textContent = 'verbinde…';

      try {
        const stats = await fetchJson('/api/stats', { method: 'GET' });
        loginCard.classList.add('hidden');
        authedArea.classList.remove('hidden');
        statusEl.textContent = 'verbunden';
        renderStats(stats);

        const [models, knowledge, profile] = await Promise.all([
          fetchJson('/api/cloud/models', { method: 'GET' }),
          fetchJson('/api/sync/knowledge', { method: 'GET' }),
          fetchJson('/api/profile', { method: 'GET' }).catch(() => null),
        ]);
        renderModels(models);
        renderKnowledge(knowledge);
        if (profile) {
          renderProfile(profile);
          renderTeam(profile);
        }
      } catch (e) {
        if (e?.status === 401) {
          statusEl.textContent = 'nicht eingeloggt';
          loginCard.classList.remove('hidden');
          authedArea.classList.add('hidden');
          statsBox.textContent = '—';
          modelsBox.textContent = '—';
          knowledgeBox.textContent = '—';
          profileBox.textContent = '—';
          teamBox.textContent = '—';
          return;
        }
        show(elError, e?.message || 'Request failed');
        statusEl.textContent = 'error';
      }
    }

    sendBtn?.addEventListener('click', async () => {
      const email = (emailInput?.value || '').trim();
      hide(elError);
      hide(elInfo);
      if (!email) {
        show(elError, 'Bitte Email eingeben.');
        return;
      }
      sendBtn.disabled = true;
      try {
        await fetchJson('/api/auth/request-link', {
          method: 'POST',
          body: JSON.stringify({ email }),
        });
        show(elInfo, 'Magic-Link gesendet. Bitte Email öffnen und Link klicken.');
      } catch (e) {
        show(elError, e?.message || 'Request failed');
      } finally {
        sendBtn.disabled = false;
      }
    });

    refreshBtn?.addEventListener('click', loadAll);

    logoutBtn?.addEventListener('click', async () => {
      hide(elError);
      hide(elInfo);
      try {
        await fetchJson('/api/auth/logout', { method: 'POST', body: '{}' });
      } catch {}
      await loadAll();
    });

    loadAll();
  </script>
</BaseLayout>

